# Copia questo file in .env e compila con i valori reali
# Il file .env NON deve essere committato su git

# Supabase (per coda stampa remota da smartphone)
SUPABASE_URL=https://TUOPROGETTO.supabase.co
SUPABASE_KEY=eyJ...

# Stampante termica (rete locale)
PRINTER_IP=192.168.1.130
PRINTER_PORT=9100

# Email SMTP (invio fatture/ricevute via email)
SMTP_HOST=out.alice.sm
SMTP_PORT=587
SMTP_USER=tuo_utente@alice.sm
SMTP_PASS=
SMTP_FROM=tuo_utente@alice.sm

# Email IMAP (per APPEND nella cartella "Posta inviata" dopo SMTP send)
# Opzionale: se IMAP_HOST e' vuoto l'append viene saltato silenziosamente.
# Le credenziali sono di solito le stesse SMTP.
IMAP_HOST=in.alice.sm
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
# Lascia IMAP_SENT_FOLDER vuoto per autodetect tra Sent / Posta inviata / INBOX.Sent / Inviati
IMAP_SENT_FOLDER=
